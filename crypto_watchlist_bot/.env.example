# This is an example file. Copy it to a new file named .env and fill in your actual credentials.

# Telegram Bot Token from BotFather
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# Your personal Telegram Chat ID. The bot will send scheduled reports to this ID.
# You can get your ID by messaging @userinfobot on Telegram.
TELEGRAM_CHAT_ID="YOUR_TELEGRAM_CHAT_ID"

# API Keys for data sources (the bot will use mock data if these are not provided)
# Get a free key from https://etherscan.io/apis
ETHERSCAN_API_KEY="YOUR_ETHERSCAN_API_KEY"

# CoinGecko API is mostly public, but a key can be used for a higher rate limit.
# Get a free key from https://www.coingecko.com/en/api
COINGECKO_API_KEY="YOUR_COINGECKO_API_KEY"
