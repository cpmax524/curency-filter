{
  "rules": [
    {
      "metric": "funding_rate",
      "condition": "less_than",
      "value": -0.0001,
      "score": 3,
      "reason": "Negative Funding (Bullish)"
    },
    {
      "metric": "total_supply",
      "condition": "greater_than",
      "value": 100000000000,
      "score": -2,
      "reason": "Very High Total Supply"
    }
  ],
  "categories": {
    "high": {
      "min_score": 3,
      "label": "🔥 High Priority"
    },
    "medium": {
      "min_score": 1,
      "label": "🔶 Medium Priority"
    },
    "low": {
      "min_score": -5,
      "label": "🧊 Low Priority"
    }
  }
}
